# ─────────────────────────────────────────────────────────────────────────────
# IBM KG — Environment variables template
# Copy to .env and fill in your values.
# Never commit .env to source control.
#
# DEMO MODE: Leave NEO4J and WATSONX sections empty — the app will start in
# fully functional mock/demo mode with realistic seed data.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
ENVIRONMENT=development

# ── Neo4j (leave blank for demo mode with mock data) ─────────────────────────
# Local dev:  NEO4J_URI=bolt://localhost:7687
# Neo4j Aura: NEO4J_URI=neo4j+s://<your-aura-instance>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── IBM watsonx.ai (leave blank for demo mode with templated narratives) ──────
# Get credentials from: https://cloud.ibm.com/resources
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2
WATSONX_EMBED_MODEL_ID=ibm/slate-125m-english-rtrvr

# ── Pruning agent ─────────────────────────────────────────────────────────────
PRUNING_INTERVAL_HOURS=6
DEFAULT_NODE_TTL_DAYS=30
STALE_DELETE_THRESHOLD_DAYS=90

# ── Search ────────────────────────────────────────────────────────────────────
SEARCH_MAX_RESULTS=25
SEARCH_SIMILARITY_THRESHOLD=0.72

# ── ChromaDB vector store (optional — semantic search layer) ──────────────────
CHROMA_PERSIST_DIR=./data/chroma
